PROJECT_NAME           = "CppTrail"
PROJECT_ICON           = @CMAKE_CURRENT_SOURCE_DIR@/resources/icon.svg
PROJECT_LOGO           = @CMAKE_CURRENT_SOURCE_DIR@/resources/icon.svg
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_SOURCE_DIR@/docs
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/include
INPUT                 += @CMAKE_CURRENT_SOURCE_DIR@/src
INPUT                 += @CMAKE_CURRENT_SOURCE_DIR@/doc
PREDEFINED             = __cplusplus=202002L DOXYGEN_WORKING
RECURSIVE              = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
MARKDOWN_SUPPORT       = YES

# Doxygen Awesome
GENERATE_TREEVIEW      = YES # required!
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_EXTRA_STYLESHEET  = @AWESOME_CSS_DIR@/doxygen-awesome.css
HTML_COLORSTYLE        = LIGHT
